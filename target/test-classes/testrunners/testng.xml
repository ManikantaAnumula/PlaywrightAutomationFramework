<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Suite">
	<listeners>
		<listener class-name="com.qa.orangehrm.listeners.MyListener"></listener>
	</listeners>
	<test name="LoginTests_chrome">
		<parameter name="browser" value="chrome" />
		<classes>
			<class name="com.qa.orangehrm.test.LoginPageTests" />
		</classes>
	</test>
	<test name="LandingTests_chormoium">
		<parameter name="browser" value="chromium" />
		<classes>
			<class name="com.qa.orangehrm.test.LandingPageTests" />
		</classes>
	</test>
	<test name="LoginTests_firefox">
		<parameter name="browser" value="firefox" />
		<classes>
			<class name="com.qa.orangehrm.test.LoginPageTests" />
		</classes>
	</test>
	<test name="LandingTests_edge">
		<parameter name="browser" value="edge" />
		<classes>
			<class name="com.qa.orangehrm.test.LandingPageTests" />
		</classes>
	</test>
</suite>
